{
  "name": "@sangfor/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "prisma generate && tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "import:finance-csv": "tsx scripts/import-finance-csv.ts",
    "cfo:snapshot": "tsx scripts/cfo-snapshot.ts",
    "cfo:restore": "tsx scripts/cfo-restore.ts",
    "cfo:reconcile": "tsx scripts/cfo-deal-reconcile.ts",
    "cfo:backfill": "tsx scripts/cfo-deal-backfill.ts",
    "cfo:ledger-backfill": "tsx scripts/cfo-ledger-backfill.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
