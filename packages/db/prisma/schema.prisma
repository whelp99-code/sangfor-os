  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  distributor Partner?    @relation("RegistrationDistributor", fields: [distributorId], references: [id])

  @@index([opportunityId])
  @@index([protectionExpiresAt, regStatus])
  @@map("deal_registrations")
}

// --- Enums ---

enum DealStatus {
  OPEN
  WON
  LOST
  ON_HOLD
  DISQUALIFIED

  @@map("deal_status")
}

enum QuoteStatus {
  DRAFT
  GATE_REVIEW
  APPROVED
  SENT
  ACCEPTED
  REJECTED

  @@map("quote_status")
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  PROPOSAL
  POC
  NEGOTIATION
  WON
  LOST

