// --- Quotes & Commerce ---

model Quote {
  id            String   @id @default(cuid())
  opportunityId String   @map("opportunity_id")
  companyId     String   @map("company_id")
  status        String   @default("draft")
  version       Int      @default(1)
  totalRevenue  Decimal  @db.Decimal(14, 2) @map("total_revenue")
  totalCost     Decimal  @db.Decimal(14, 2) @map("total_cost")
  marginPct     Decimal  @db.Decimal(8, 2) @map("margin_pct")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  opportunity      Opportunity      @relation(fields: [opportunityId], references: [id])
  lineItems        QuoteLineItem[]
  discountRequests DiscountRequest[]

  @@index([opportunityId])
  @@index([companyId, status])
  @@map("quotes")
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  skuId       String  @map("sku_id")
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  costPrice   Decimal @db.Decimal(12, 2) @map("cost_price")
  discountPct Decimal @db.Decimal(5, 2) @default(0) @map("discount_pct")
  revenue     Decimal @db.Decimal(14, 2)
  cost        Decimal @db.Decimal(14, 2)
  marginPct   Decimal @db.Decimal(8, 2) @map("margin_pct")

  quote Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sku   ProductSku @relation(fields: [skuId], references: [id])

  @@index([quoteId])
  @@map("quote_line_items")
}

model DiscountRequest {
  id                String   @id @default(cuid())
  quoteId           String   @map("quote_id")
  requestedDiscount Decimal  @db.Decimal(5, 2) @map("requested_discount")
  reason            String
  status            String   @default("pending")
  approvedBy        String?  @map("approved_by")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("discount_requests")
}

// --- Vendor ---

model VendorRequest {
  id            String   @id @default(cuid())
  opportunityId String?  @map("opportunity_id")
  requestType   String   @map("request_type")
  vendorName    String   @map("vendor_name")
  detailsJson   Json     @map("details_json")
  status        String   @default("draft")
  createdBy     String   @map("created_by")

  opportunity Opportunity?         @relation(fields: [opportunityId], references: [id])
  events      VendorRequestEvent[]

  @@index([opportunityId])
  @@index([status])
  @@map("vendor_requests")
}

model VendorRequestEvent {
  id          String   @id @default(cuid())
  requestId   String   @map("request_id")
  eventType   String   @map("event_type")
  description String?
  createdBy   String?  @map("created_by")

  request VendorRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("vendor_request_events")
}

// --- Delivery ---

// Engagement = the project an Opportunity converts into once a POC plan is
// confirmed with the customer. Renamed from DeliveryProject (table preserved via
// @@map). Absorbs proposals / POC / meetings / quote-derived amount.
model Engagement {
  id                 String    @id @default(cuid())
  opportunityId      String    @unique @map("opportunity_id")
  projectId          String?   @map("project_id")
  customerId         String?   @map("customer_id")
  name               String
  status             String    @default("planned")
  amount             Decimal?  @db.Decimal(12, 2)
  amountQuoteId      String?   @map("amount_quote_id")
  summaryMarkdown    String?   @map("summary_markdown")
  convertedAt        DateTime? @map("converted_at")
  convertedFromStage String?   @map("converted_from_stage")
  sowApprovedAt      DateTime? @map("sow_approved_at")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")

  opportunity        Opportunity            @relation(fields: [opportunityId], references: [id])
  checklistItems     DeliveryChecklistItem[]
  generatedDocuments GeneratedDocument[]
  meetingNotes       MeetingNote[]

  @@map("delivery_projects")
}

model DeliveryChecklistItem {
  id          String    @id @default(cuid())
  deliveryId  String    @map("delivery_id")
  itemKey     String    @map("item_key")
  status      String    @default("pending")
  completedAt DateTime? @map("completed_at")

  delivery Engagement @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("delivery_checklist_items")
}

// Meeting notes (미팅내용). Manually authored or promoted from a mail thread.
// Absorbed into an Engagement on conversion. `@@unique` keeps thread-promotion idempotent.
model MeetingNote {
  id                  String    @id @default(cuid())
  opportunityId       String?   @map("opportunity_id")
  engagementId        String?   @map("engagement_id")
  customerId          String?   @map("customer_id")
  mailInsightThreadId String?   @map("mail_insight_thread_id")
  title               String
  occurredAt          DateTime? @map("occurred_at")
  attendees           String[]  @default([])
  bodyMarkdown        String    @map("body_markdown")
  source              String    @default("manual")
  status              String    @default("confirmed")
  createdAt           DateTime  @default(now()) @map("created_at")

  engagement Engagement? @relation(fields: [engagementId], references: [id])

  @@unique([opportunityId, mailInsightThreadId])
  @@index([opportunityId])
  @@index([engagementId])
  @@map("meeting_notes")
}

// --- Support ---

model SupportCase {
  id          String    @id @default(cuid())
  customerId  String    @map("customer_id")
  subject     String
  severity    String    @default("medium")
  status      String    @default("open")
