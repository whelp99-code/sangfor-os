  vendor      String
  name        String
  description String?

  editions        ProductEdition[]
  sizingTemplates SizingTemplate[]

  @@map("product_families")
}

model ProductEdition {
  id       String @id @default(cuid())
  familyId String @map("family_id")
  name     String
  version  String

  family ProductFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  skus   ProductSku[]

  @@index([familyId])
  @@map("product_editions")
}

model ProductSku {
  id            String   @id @default(cuid())
  editionId     String   @map("edition_id")
  skuCode       String   @unique @map("sku_code")
  name          String
  unitPrice     Decimal?  @db.Decimal(12, 2) @map("unit_price")
  unitCost      Decimal?  @db.Decimal(12, 2) @map("unit_cost")
  licenseMetric String?  @map("license_metric")

  edition                  ProductEdition       @relation(fields: [editionId], references: [id])
  quoteLineItems           QuoteLineItem[]
  sourceCompatibilityRules CompatibilityRule[]  @relation("SourceSku")
  targetCompatibilityRules CompatibilityRule[]  @relation("TargetSku")
  assetLicenses            AssetLicense[]
  subscriptions            Subscription[]

  @@index([editionId])
  @@map("product_skus")
}

model LicenseMetric {
  id   String @id @default(cuid())
  key  String @unique
  name String
  unit String

  @@map("license_metrics")
}

model SizingTemplate {
  id              String @id @default(cuid())
