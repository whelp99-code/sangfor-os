  configJson      Json   @map("config_json")

  family ProductFamily @relation(fields: [productFamilyId], references: [id], onDelete: Cascade)

  @@index([productFamilyId])
  @@map("sizing_templates")
}

model CompatibilityRule {
  id          String @id @default(cuid())
  sourceSkuId String @map("source_sku_id")
  targetSkuId String @map("target_sku_id")
  ruleType    String @map("rule_type")
  configJson  Json   @map("config_json")

  sourceSku ProductSku @relation("SourceSku", fields: [sourceSkuId], references: [id], onDelete: Cascade)
  targetSku ProductSku @relation("TargetSku", fields: [targetSkuId], references: [id], onDelete: Cascade)

  @@index([sourceSkuId])
  @@index([targetSkuId])
  @@map("compatibility_rules")
}

// --- Channel ---

model DealRegistration {
  id                  String    @id @default(cuid())
  opportunityId       String    @unique @map("opportunity_id")
  distributorId       String?   @map("distributor_id")
  registrationNumber  String?   @map("registration_number")
  regStatus           RegStatus @default(NOT_SUBMITTED) @map("reg_status")
  protectionExpiresAt DateTime? @map("protection_expires_at")
  sprStatus           String?   @map("spr_status")
  partnerTierMargin   Decimal?  @db.Decimal(5, 2) @map("partner_tier_margin")
  conflictNote        String?   @map("conflict_note")
  createdAt           DateTime  @default(now()) @map("created_at")
