  vendorEscalations VendorEscalation[]

  @@index([customerId])
  @@index([status, severity])
  @@map("support_cases")
}

model VendorEscalation {
  id         String  @id @default(cuid())
  caseId     String  @map("case_id")
  vendor     String
  reason     String
  status     String  @default("draft")
  resolution String?

  supportCase SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("vendor_escalations")
}

// --- Assets & Licensing ---

model AssetLicense {
  id          String    @id @default(cuid())
  assetId     String    @map("asset_id")
  skuId       String    @map("sku_id")
  licenseKey  String?   @map("license_key")
  status      String    @default("active")
  activatedAt DateTime? @map("activated_at")
  expiresAt   DateTime? @map("expires_at")

  asset CustomerAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sku   ProductSku    @relation(fields: [skuId], references: [id])

  @@index([assetId])
  @@map("asset_licenses")
}

model Subscription {
  id        String    @id @default(cuid())
  assetId   String    @map("asset_id")
  skuId     String    @map("sku_id")
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  status    String    @default("active")
  autoRenew Boolean   @default(false) @map("auto_renew")

  asset CustomerAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sku   ProductSku    @relation(fields: [skuId], references: [id])

  @@index([assetId])
  @@index([endDate, status])
  @@map("subscriptions")
}

model MaintenanceContract {
  id        String    @id @default(cuid())
  assetId   String    @map("asset_id")
  vendor    String
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  status    String    @default("active")

  asset CustomerAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("maintenance_contracts")
}

// --- AI ---

model AiPromptTemplate {
  id         String  @id @default(cuid())
  key        String  @unique
  name       String
  promptText String  @map("prompt_text")
  version    Int     @default(1)
  modelId    String? @map("model_id")

  promptRuns AiPromptRun[]

  @@map("ai_prompt_templates")
}

model AiModel {
  id                       String   @id @default(cuid())
  provider                 String
  modelName                String   @map("model_name")
  allowedDataClassification String[] @map("allowed_data_classification")
  isActive                 Boolean  @default(true) @map("is_active")

  @@map("ai_models")
}

model AiEvaluationDataset {
  id                String @id @default(cuid())
  name              String
  category          String
  version           Int    @default(1)
  goldenAnswerCount Int    @default(0) @map("golden_answer_count")

  @@map("ai_evaluation_datasets")
}

model AiPromptRun {
  id               String   @id @default(cuid())
  promptTemplateId String   @map("prompt_template_id")
  inputJson        Json     @map("input_json")
  outputJson       Json     @map("output_json")
  tokensUsed       Int?     @map("tokens_used")
  latencyMs        Int?     @map("latency_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  promptTemplate AiPromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Cascade)

  @@index([promptTemplateId])
  @@map("ai_prompt_runs")
}

// --- Security & Audit ---

model DataExportRequest {
  id          String  @id @default(cuid())
  artifactId  String  @map("artifact_id")
  requestedBy String  @map("requested_by")
  reason      String
  status      String  @default("pending")
  approvedBy  String? @map("approved_by")

  @@map("data_export_requests")
}

model ArtifactAccessEvent {
  id         String   @id @default(cuid())
  artifactId String   @map("artifact_id")
  userId     String   @map("user_id")
  accessType String   @map("access_type")
  timestamp  DateTime @default(now())

  @@index([artifactId])
  @@map("artifact_access_events")
}

model NotificationEvent {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  channel     String
  eventType   String   @map("event_type")
  payloadJson Json     @map("payload_json")
  status      String   @default("pending")
  sentAt      DateTime? @map("sent_at")

  @@index([companyId, eventType])
  @@map("notification_events")
}

// --- Color Agent ---

model ColorReviewRequirement {
  id           String    @id @default(cuid())
  handoffCardId String   @map("handoff_card_id")
  colorKey     String    @map("color_key")
  status       String    @default("pending")
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")

  handoffCard KanbanHandoffCard @relation(fields: [handoffCardId], references: [id], onDelete: Cascade)

  @@index([handoffCardId])
  @@map("color_review_requirements")
}

model ColorAgentDecision {
  id           String   @id @default(cuid())
  handoffCardId String  @map("handoff_card_id")
  colorKey     String   @map("color_key")
  decision     String
  reason       String?
  decidedBy    String?  @map("decided_by")

  handoffCard KanbanHandoffCard @relation(fields: [handoffCardId], references: [id], onDelete: Cascade)

  @@index([handoffCardId])
  @@map("color_agent_decisions")
}
