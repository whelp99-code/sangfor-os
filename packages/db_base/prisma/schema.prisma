// AI Automation Work Portal — DB Kernel (Phase 1)
// Purpose: PostgreSQL multi-schema foundation for automation, audit, and UI registries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- core ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectMembers ProjectMember[]
  commandRuns    CommandRun[]    @relation("CommandRunRequestedBy")

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     ProjectMember[]
  commandRuns CommandRun[]
  mailInsightThreads MailInsightThread[]
  policyMemories     PolicyMemory[]
  policyDecisionLogs PolicyDecisionLog[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Workspace {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("workspaces")
}

model ConfigProfile {
  id        String   @id @default(cuid())
  key       String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  values ConfigValue[]

  @@map("config_profiles")
}

model ConfigValue {
  id        String   @id @default(cuid())
  profileId String   @map("profile_id")
  key       String
  valueJson Json     @map("value_json")
  createdAt DateTime @default(now()) @map("created_at")

  profile ConfigProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, key])
  @@map("config_values")
}

// --- automation (execution chain) ---

model Command {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  runs CommandRun[]

  @@map("commands")
}

model CommandRun {
  id              String   @id @default(cuid())
  commandId       String   @map("command_id")
  projectId       String   @map("project_id")
  requestedById   String?  @map("requested_by_id")
  status          String   @default("pending")
  inputSummary    String?  @map("input_summary")
  sourceEntityType String? @map("source_entity_type")
  sourceEntityId   String? @map("source_entity_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  command     Command    @relation(fields: [commandId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])
  requestedBy User?      @relation("CommandRunRequestedBy", fields: [requestedById], references: [id])
  workflows   Workflow[]
  intent      IntentAnalysis?
  risk        RiskAnalysis?
  codeChanges CodeChange[] @relation("CommandRunCodeChanges")
  skillRuns   SkillRun[]
  workBreakdownItems WorkBreakdownItem[]
  improvementCandidates ImprovementCandidate[]

  @@index([projectId, status])
  @@index([commandId])
  @@index([sourceEntityType, sourceEntityId])
  @@map("command_runs")
}

model ImprovementCandidate {
  id              String   @id @default(cuid())
  sourceType      String   @map("source_type")
  sourceId        String?  @map("source_id")
  title           String
  summary         String
  severity        String   @default("medium")
  suggestedModule String?  @map("suggested_module")
  suggestedAction String?  @map("suggested_action")
  status          String   @default("proposed")
  commandRunId    String?  @map("command_run_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  commandRun CommandRun? @relation(fields: [commandRunId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("improvement_candidates")
}

model Workflow {
  id           String   @id @default(cuid())
  commandRunId String   @map("command_run_id")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  commandRun CommandRun      @relation(fields: [commandRunId], references: [id], onDelete: Cascade)
  steps      WorkflowStep[]

  @@index([commandRunId])
  @@map("workflows")
}

model WorkflowStep {
  id         String   @id @default(cuid())
  workflowId String   @map("workflow_id")
  stepKey    String   @map("step_key")
  status     String   @default("pending")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  workflow          Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agentAssignments  AgentAssignment[]
  validationResults ValidationResult[]

  @@index([workflowId, sortOrder])
  @@map("workflow_steps")
}

model AgentAssignment {
  id             String   @id @default(cuid())
  workflowStepId String   @map("workflow_step_id")
  agentKey       String   @map("agent_key")
  status         String   @default("assigned")
  createdAt      DateTime @default(now()) @map("created_at")

  workflowStep WorkflowStep @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)
  toolCalls    ToolCall[]
  messages     AgentMessage[]
  decisions    AgentDecisionLog[]

  @@index([workflowStepId])
  @@map("agent_assignments")
}

model ToolCall {
  id                String   @id @default(cuid())
  agentAssignmentId String   @map("agent_assignment_id")
  toolKey           String   @map("tool_key")
  status            String   @default("pending")
  errorJson         Json?    @map("error_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agentAssignment AgentAssignment @relation(fields: [agentAssignmentId], references: [id], onDelete: Cascade)

  @@index([agentAssignmentId])
  @@map("tool_calls")
}

model ValidationResult {
  id             String   @id @default(cuid())
  workflowStepId String   @map("workflow_step_id")
  checkKey       String   @map("check_key")
  status         String
  detailsJson    Json?    @map("details_json")
  createdAt      DateTime @default(now()) @map("created_at")

  workflowStep WorkflowStep @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)
  reports      Report[]

  @@index([workflowStepId])
  @@map("validation_results")
}

model Report {
  id                 String   @id @default(cuid())
  validationResultId String   @map("validation_result_id")
  title              String
  bodyMarkdown       String?  @map("body_markdown")
  createdAt          DateTime @default(now()) @map("created_at")

  validationResult ValidationResult @relation(fields: [validationResultId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model IntentAnalysis {
  id           String   @id @default(cuid())
  commandRunId String   @unique @map("command_run_id")
  summary      String
  intentJson   Json     @map("intent_json")
  createdAt    DateTime @default(now()) @map("created_at")

  commandRun CommandRun @relation(fields: [commandRunId], references: [id], onDelete: Cascade)

  @@map("intent_analyses")
}

model RiskAnalysis {
  id           String   @id @default(cuid())
  commandRunId String   @unique @map("command_run_id")
  riskLevel    String   @map("risk_level")
  riskJson     Json     @map("risk_json")
  createdAt    DateTime @default(now()) @map("created_at")

  commandRun CommandRun @relation(fields: [commandRunId], references: [id], onDelete: Cascade)

  @@map("risk_analyses")
}

model AgentMessage {
  id                String   @id @default(cuid())
  agentAssignmentId String   @map("agent_assignment_id")
  role              String
  content           String
  createdAt         DateTime @default(now()) @map("created_at")

  agentAssignment AgentAssignment @relation(fields: [agentAssignmentId], references: [id], onDelete: Cascade)

  @@index([agentAssignmentId])
  @@map("agent_messages")
}

model AgentDecisionLog {
  id                String   @id @default(cuid())
  agentAssignmentId String   @map("agent_assignment_id")
  decision          String
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")

  agentAssignment AgentAssignment @relation(fields: [agentAssignmentId], references: [id], onDelete: Cascade)

  @@index([agentAssignmentId])
  @@map("agent_decision_logs")
}

model ApprovalRequest {
  id            String   @id @default(cuid())
  commandRunId  String?  @map("command_run_id")
  pullRequestId String?  @map("pull_request_id")
  status        String   @default("pending")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("approval_requests")
}

// --- dev ---

model Repository {
  id        String   @id @default(cuid())
  slug      String   @unique
  remoteUrl String?  @map("remote_url")
  createdAt DateTime @default(now()) @map("created_at")

  pullRequests PullRequest[]
  branches     Branch[]

  @@map("repositories")
}

model Branch {
  id           String   @id @default(cuid())
  repositoryId String   @map("repository_id")
  name         String
  headSha      String?  @map("head_sha")
  createdAt    DateTime @default(now()) @map("created_at")

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
  @@map("branches")
}

model PullRequest {
  id           String   @id @default(cuid())
  repositoryId String   @map("repository_id")
  number       Int
  title        String
  status       String   @default("open")
  url          String?
  ciStatus     String?  @map("ci_status")
  createdAt    DateTime @default(now()) @map("created_at")

  repository Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  codeChanges CodeChange[]

  @@unique([repositoryId, number])
  @@map("pull_requests")
}

model CodeChange {
  id            String   @id @default(cuid())
  pullRequestId String?  @map("pull_request_id")
  commandRunId  String?  @map("command_run_id")
  summary       String
  createdAt     DateTime @default(now()) @map("created_at")

  pullRequest PullRequest?  @relation(fields: [pullRequestId], references: [id])
  commandRun  CommandRun?   @relation("CommandRunCodeChanges", fields: [commandRunId], references: [id])
  changedFiles ChangedFile[]
  buildRuns   BuildRun[]

  @@index([commandRunId])
  @@map("code_changes")
}

model BuildRun {
  id           String   @id @default(cuid())
  codeChangeId String?  @map("code_change_id")
  commandRunId String?  @map("command_run_id")
  status       String   @default("pending")
  logSummary   String?  @map("log_summary")
  createdAt    DateTime @default(now()) @map("created_at")

  codeChange CodeChange? @relation(fields: [codeChangeId], references: [id])
  testRuns   TestRun[]

  @@index([commandRunId])
  @@map("build_runs")
}

model TestRun {
  id           String   @id @default(cuid())
  buildRunId   String?  @map("build_run_id")
  commandRunId String?  @map("command_run_id")
  status       String   @default("pending")
  passed       Int      @default(0)
  failed       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  buildRun BuildRun? @relation(fields: [buildRunId], references: [id])

  @@index([commandRunId])
  @@map("test_runs")
}

model ChangedFile {
  id           String @id @default(cuid())
  codeChangeId String @map("code_change_id")
  path         String
  changeType   String @map("change_type")

  codeChange CodeChange @relation(fields: [codeChangeId], references: [id], onDelete: Cascade)

  @@index([codeChangeId])
  @@map("changed_files")
}

// --- ui / module registry ---

model ModuleRegistry {
  id             String   @id @default(cuid())
  moduleKey      String   @unique @map("module_key")
  displayName    String   @map("display_name")
  version        String   @default("0.1.0")
  dependencyJson Json?    @map("dependency_json")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")

  blocks BlockRegistry[]
  nodes  NodeRegistry[]

  @@map("module_registry")
}

model BlockRegistry {
  id          String   @id @default(cuid())
  blockKey    String   @unique @map("block_key")
  moduleKey   String   @map("module_key")
  displayName String   @map("display_name")
  configJson  Json?    @map("config_json")
  createdAt   DateTime @default(now()) @map("created_at")

  module      ModuleRegistry @relation(fields: [moduleKey], references: [moduleKey])
  layoutSlots LayoutSlot[]

  @@index([moduleKey])
  @@map("block_registry")
}

model LayoutSlot {
  id              String  @id @default(cuid())
  pageKey         String  @map("page_key")
  slotKey         String  @map("slot_key")
  sortOrder       Int     @default(0) @map("sort_order")
  blockRegistryId String? @map("block_registry_id")

  block BlockRegistry? @relation(fields: [blockRegistryId], references: [id])

  @@unique([pageKey, slotKey])
  @@index([pageKey, sortOrder])
  @@map("layout_slots")
}

model NodeRegistry {
  id         String   @id @default(cuid())
  nodeKey    String   @unique @map("node_key")
  moduleKey  String   @map("module_key")
  nodeType   String   @map("node_type")
  configJson Json?    @map("config_json")
  createdAt  DateTime @default(now()) @map("created_at")

  module ModuleRegistry @relation(fields: [moduleKey], references: [moduleKey])

  @@index([moduleKey])
  @@map("node_registry")
}

model QueryRegistry {
  id          String   @id @default(cuid())
  queryKey    String   @unique @map("query_key")
  sourceType  String   @map("source_type")
  configJson  Json     @map("config_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("query_registry")
}

// --- audit (required for all state changes / async) ---

model StateTransitionLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  actorType  String?  @map("actor_type")
  actorId    String?  @map("actor_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("state_transition_logs")
}

model OutboxEvent {
  id            String    @id @default(cuid())
  eventType     String    @map("event_type")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  payload       Json
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")

  @@index([status, createdAt])
  @@map("outbox_events")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  actorId   String?  @map("actor_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model ErrorEvent {
  id         String   @id @default(cuid())
  source     String
  message    String
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("error_events")
}

model ValidationPlan {
  id           String   @id @default(cuid())
  commandRunId String?  @map("command_run_id")
  name         String
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  checks ValidationCheck[]

  @@map("validation_plans")
}

model ValidationCheck {
  id       String @id @default(cuid())
  planId   String @map("plan_id")
  checkKey String @map("check_key")
  status   String @default("pending")

  plan ValidationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("validation_checks")
}

model QualityGate {
  id             String   @id @default(cuid())
  gateKey        String   @unique @map("gate_key")
  requiredChecks Json     @map("required_checks")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("quality_gates")
}

model CostEvent {
  id           String   @id @default(cuid())
  commandRunId String?  @map("command_run_id")
  source       String
  amountUsd    Float    @map("amount_usd")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([commandRunId])
  @@map("cost_events")
}

model MailAccount {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  provider  String   @default("outlook")
  email     String
  status    String   @default("mock")
  createdAt DateTime @default(now()) @map("created_at")

  messages MailMessage[]

  @@map("mail_accounts")
}

model MailMessage {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  subject     String
  fromEmail   String   @map("from_email")
  bodyPreview String?  @map("body_preview")
  groupKey    String?  @map("group_key")
  createdAt   DateTime @default(now()) @map("created_at")

  account MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("mail_messages")
}

model PortalTask {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  title     String
  status    String   @default("open")
  source    String   @default("portal")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId, status])
  @@map("portal_tasks")
}

// --- portal business (Phase 12) ---

model Customer {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  domain    String?
  industry  String?
  status    String   @default("active")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contacts     Contact[]
  partnerLinks CustomerPartnerLink[]
  activityLogs CustomerActivityLog[]
  workTasks    WorkTask[]
  pocProjects  PocProject[]
  opportunities Opportunity[]
  generatedDocuments GeneratedDocument[]

  @@index([projectId, name])
  @@map("customers")
}

model Partner {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  partnerType String?  @map("partner_type")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customerLinks CustomerPartnerLink[]
  contacts      Contact[]
  workTasks     WorkTask[]
  pocProjects   PocProject[]
  opportunities Opportunity[]

  @@index([projectId, name])
  @@map("partners")
}

model Contact {
  id         String   @id @default(cuid())
  customerId String?  @map("customer_id")
  partnerId  String?  @map("partner_id")
  name       String
  email      String?
  phone      String?
  role       String?
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  partner  Partner?  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([partnerId])
  @@index([email])
  @@map("contacts")
}

model CustomerPartnerLink {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  partnerId  String   @map("partner_id")
  linkType   String   @default("reseller") @map("link_type")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  partner  Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([customerId, partnerId])
  @@map("customer_partner_links")
}

model CustomerActivityLog {
  id           String   @id @default(cuid())
  customerId   String   @map("customer_id")
  activityType String   @map("activity_type")
  summary      String
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_activity_logs")
}

model WorkTask {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  title        String
  status       String    @default("todo")
  priority     String    @default("normal")
  dueAt        DateTime? @map("due_at")
  customerId   String?   @map("customer_id")
  partnerId    String?   @map("partner_id")
  source       String    @default("manual")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id])
  partner  Partner?  @relation(fields: [partnerId], references: [id])
  links    TaskLink[]
  statusEvents TaskStatusEvent[]

  @@index([projectId, status])
  @@index([projectId, dueAt])
  @@map("work_tasks")
}

model TaskLink {
  id         String   @id @default(cuid())
  workTaskId String   @map("work_task_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  linkType   String   @default("related") @map("link_type")
  createdAt  DateTime @default(now()) @map("created_at")

  workTask WorkTask @relation(fields: [workTaskId], references: [id], onDelete: Cascade)

  @@unique([workTaskId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("task_links")
}

model TaskStatusEvent {
  id         String   @id @default(cuid())
  workTaskId String   @map("work_task_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  actorType  String   @default("user") @map("actor_type")
  createdAt  DateTime @default(now()) @map("created_at")

  workTask WorkTask @relation(fields: [workTaskId], references: [id], onDelete: Cascade)

  @@index([workTaskId])
  @@map("task_status_events")
}

model PocProject {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  customerId      String?   @map("customer_id")
  partnerId       String?   @map("partner_id")
  title           String
  productName     String?   @map("product_name")
  productLine     String?   @map("product_line")
  deploymentType  String?   @map("deployment_type")
  hwSpec          String?   @map("hw_spec")
  swSpec          String?   @map("sw_spec")
  networkNotes    String?   @map("network_notes")
  scheduleAt      DateTime? @map("schedule_at")
  status          String    @default("planning")
  requirements    String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  customer        Customer? @relation(fields: [customerId], references: [id])
  partner         Partner?  @relation(fields: [partnerId], references: [id])
  checklistItems  PocChecklistItem[]
  issues          PocIssue[]
  requirementRows PocRequirement[]
  events          PocEvent[]
  resultReports   PocResultReport[]
  generatedDocuments GeneratedDocument[]

  @@index([projectId, status])
  @@map("poc_projects")
}

model PocChecklistItem {
  id           String   @id @default(cuid())
  pocProjectId String   @map("poc_project_id")
  label        String
  done         Boolean  @default(false)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  pocProject PocProject @relation(fields: [pocProjectId], references: [id], onDelete: Cascade)

  @@index([pocProjectId])
  @@map("poc_checklist_items")
}

model PocIssue {
  id           String   @id @default(cuid())
  pocProjectId String   @map("poc_project_id")
  title        String
  severity     String   @default("medium")
  status       String   @default("open")
  createdAt    DateTime @default(now()) @map("created_at")

  pocProject PocProject @relation(fields: [pocProjectId], references: [id], onDelete: Cascade)

