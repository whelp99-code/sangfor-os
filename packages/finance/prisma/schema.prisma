generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FinanceProject {
  id        String         @id @default(cuid())
  name      String
  status    String?        @default("active")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  invoices  Invoice[]
  expenses  Expense[]
  cashflows Cashflow[]
}

model Invoice {
  id             String        @id @default(cuid())
  projectId      String?
  project        FinanceProject? @relation(fields: [projectId], references: [id])
  amount         Int           @default(0)
  vat            Int           @default(0)
  total          Int           @default(0)
  depositAmount  Int?
  depositStatus  String?       @default("미수")
  depositDate    DateTime?
  buyer          String?
  memo           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  taxInvoices    TaxInvoice[]

  @@map("finance_invoices")
}

model Expense {
  id            String         @id @default(cuid())
  projectId     String?
  project       FinanceProject? @relation(fields: [projectId], references: [id])
  expenseName   String         @default("")
  amount        Int            @default(0)
  vat           Int            @default(0)
  total         Int            @default(0)
  category      String?        @default("기타")
  vendor        String?
  date          DateTime       @default(now())
  proofType     String?
  paymentMethod String?
  isPaid        Boolean        @default(false)
  memo          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("finance_expenses")
}

model LedgerEntry {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  description    String   @default("")
  debitAccount   String   @map("debit_account")
  creditAccount  String   @map("credit_account")
  amount         Int      @default(0)
  reference      String?
  referenceType  String?  @map("reference_type")
  memo           String?

  @@map("finance_ledger_entries")
}

model Cashflow {
  id           String         @id @default(cuid())
  projectId    String?
  project      FinanceProject? @relation(fields: [projectId], references: [id])
  counterparty String         @default("")
  amount       Int            @default(0)
  cashChange   Int            @default(0)
  type         String         @default("")
  outAccount   String?        @map("out_account")
  inAccount    String?        @map("in_account")
  date         DateTime       @default(now())
  memo         String?

  @@map("finance_cashflows")
}

model Subscription {
  id               String   @id @default(cuid())
  name             String   @default("")
  vendor           String?
  amount           Int      @default(0)
  currency         String   @default("KRW")
  cycle            String   @default("monthly")
  category         String?
  nextBillingDate  DateTime @map("next_billing_date")
  paymentMethod    String?  @map("payment_method")
  notifyDaysBefore Int      @default(7) @map("notify_days_before")
  isActive         Boolean  @default(true) @map("is_active")
  memo             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("finance_subscriptions")
}

model MonthClose {
  id                 String   @id @default(cuid())
  year               Int
  month              Int
  status             String   @default("in_progress")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  totalRevenue       Int?     @map("total_revenue")
  totalExpense       Int?     @map("total_expense")
  netIncome          Int?     @map("net_income")
  uncategorizedCount Int?     @map("uncategorized_count")
  notes              String?

  @@unique([year, month])
  @@map("finance_month_closes")
}

model TaxInvoice {
  id              String   @id @default(cuid())
  invoiceId       String?  @map("invoice_id")
  projectId       String?  @map("project_id")
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  direction       String   @default("sales")
  status          String   @default("draft")
  supplierCorpNum String   @map("supplier_corp_num")
  supplierName    String   @map("supplier_name")
  buyerCorpNum    String   @map("buyer_corp_num")
  buyerName       String   @map("buyer_name")
  supplyAmount    Int      @default(0) @map("supply_amount")
  vatAmount       Int      @default(0) @map("vat_amount")
  totalAmount     Int      @default(0) @map("total_amount")
  issueDate       DateTime @map("issue_date")
  memo            String?
  rawResponse     String?  @map("raw_response")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("finance_tax_invoices")
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("새 대화")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]

  @@map("finance_chat_sessions")
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String      @map("session_id")
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String      @default("user")
  content    String      @default("")
  toolName   String?     @map("tool_name")
  toolResult String?     @map("tool_result")
  createdAt  DateTime    @default(now())

  @@index([sessionId])
  @@map("finance_chat_messages")
}

model FinanceAccount {
  id           String    @id @default(cuid())
  type         String    @default("bank")
  organization String    @default("")
  accountName  String    @map("account_name")
  accountNum   String?   @map("account_num")
  connectedId  String?   @map("connected_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastSyncedAt DateTime? @map("last_synced_at")
  memo         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("finance_accounts")
}
