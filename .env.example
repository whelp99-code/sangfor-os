DATABASE_URL="postgresql://ai_portal:ai_portal@localhost:5434/ai_automation_portal?schema=public"
REDIS_URL="redis://localhost:6380"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Phase 1+ placeholders (empty OK for CI without secrets)
JWT_SECRET=""
# Required when JWT_SECRET is set (min 8 chars); login rejects without matching password
AUTH_DEMO_PASSWORD=""
OPENAI_API_KEY=""
# MiMo OpenAI-compatible API — https://platform.xiaomimimo.com/docs/en-US/api/chat/openai-api
# Token Plan (Subscription): tp- key + token-plan-* base URL
# Pay-as-you-go (API Keys): sk- key + https://api.xiaomimimo.com/v1 (auto-resolved if mismatched)
OPENAI_BASE_URL="https://token-plan-sgp.xiaomimimo.com/v1"
OPENAI_MODEL="mimo-v2.5-pro"
# Optional: phase13 runtime tuning
# OPENAI_MAX_COMPLETION_TOKENS="2048"
# PHASE13_SKILL_DOC_MAX_CHARS="2000"
# PHASE13_SKILL_CONCURRENCY="3"
# PHASE13_LLM_ALL="0" # 1이면 PM/AIOS 전체 스킬을 live LLM으로 실행
# PHASE13_SKILL_KEYS is deprecated; use executionProfile="smoke" from API caller.

# Optional open-source knowledge stack
# db: use built-in Prisma chunk search only
# lightrag: try LightRAG first, then fall back to built-in search
KNOWLEDGE_BACKEND="db"
KNOWLEDGE_INGEST_ENABLED="false"
LIGHTRAG_BASE_URL="http://localhost:9621"
LIGHTRAG_TIMEOUT_MS="8000"
LIGHTRAG_QUERY_MODE="mix"
OLLAMA_BASE_URL="http://localhost:11434"
OPENKB_WORKDIR="/Users/jmpark/Documents/Playground/AIOS v1/knowledge"
GRAPHIFY_OUT="/Users/jmpark/Documents/Playground/AIOS v1/knowledge/graphify-out"

# Phase 11 connector staging gate
# mock: keys may be empty and connector calls use local/mock-safe fallbacks.
# real: scripts/check-staging-connectors.sh requires all connector credentials below.
CONNECTOR_STAGING_MODE="mock"
GITHUB_TOKEN=""
NOTION_API_KEY=""
OUTLOOK_CLIENT_ID=""
OUTLOOK_CLIENT_SECRET=""
OUTLOOK_TENANT_ID=""
CONNECTOR_RATE_LIMIT_PER_MINUTE="60"
CONNECTOR_TIMEOUT_MS="10000"

# Optional Langfuse observability (no-op when unset)
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# Optional Sentry APM (no-op when unset; required for v1.0.1 staging evidence)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="staging"
SENTRY_TRACES_SAMPLE_RATE="0.1"
# Set to 1 to allow POST /api/ops/apm-test (staging/local only)
APM_TEST_ROUTE_ENABLED="0"

# Standalone Mail Intelligence OAuth check (release gate)
MAIL_OAUTH_BASE_URL="http://localhost:3010"

# Local APM bootstrap (optional): docker compose -f docker-compose.yml -f docker-compose.glitchtip.yml --profile apm up -d
# Then: bash ./scripts/setup-local-apm-evidence.sh  (writes gitignored .env.local)

# Set to 1 to run postgres/redis integration tests locally or in CI
# Dashboard API Key authentication (comma-separated keys; empty = open access)
DASHBOARD_API_KEYS=""
CI_INTEGRATION="0"

# CFO/finance API key (apps/api /api/cfo). In production (NODE_ENV=production)
# requests require x-api-key matching FINANCE_API_KEY; in development the API
# allows access without a key when none is configured. The web app forwards
# this same key from its server-side proxy, so set it identically for both.
FINANCE_API_KEY=""
