{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@sangfor/workflow-engine": ["packages/workflow-engine/src/index.ts"],
      "@sangfor/workflow-core": ["packages/workflow-core/src/index.ts"],
      "@sangfor/wiki-sync": ["packages/wiki-sync/src/index.ts"],
      "@sangfor/health-checker": ["packages/health-checker/src/index.ts"],
      "@sangfor/workflow-shared": ["packages/shared/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["packages/*/src/**/*.ts", "apps/*/src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
