# ─── Sangfor MCP Workflow — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.

# ─── Operator Console API Key (required for dev:web) ──────────────────────────
SANGFOR_API_KEY=dev-test-key

# Engineer MCP repo path (device learn / workflow tool execution)
SANGFOR_MCP_CWD=/Users/me/Documents/Playground/whelp99-code-sangfor-engineer-mcp

# ─── Product Credentials (EPP / IAG / CC) ─────────────────────────────────────
EPP_USERNAME=admin
EPP_PASSWORD=
IAG_USERNAME=admin
IAG_PASSWORD=
CC_USERNAME=admin
CC_PASSWORD=

# CAPTCHA OCR — LM Studio vision (권장) 또는 Tesseract
# LM Studio 실행 + vision 모델 로드 (예: qwen/qwen3.5-9b)
LM_STUDIO_VISION_MODEL=qwen/qwen3.5-9b
LM_STUDIO_VISION_ENDPOINT=http://localhost:1234/v1/chat/completions
LM_STUDIO_API_KEY=lm-studio
# If set, all tools/call requests must include a matching "authKey" parameter.
# Leave empty to disable authentication (development only).
MCP_API_KEY=

# ─── Allowed File Directories (comma-separated) ───────────────────────────────
# Directories from which parse_excel can read files.
# Defaults to $HOME/Documents and the project working directory.
# ALLOWED_FILE_DIRS=/Users/me/Documents,/home/me/projects
